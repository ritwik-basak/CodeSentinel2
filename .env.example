# GitHub Personal Access Token
# Generate one at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or no scopes (for public repos only)
GITHUB_TOKEN=your_github_token_here

# Pinecone API Key
# Get yours at: https://app.pinecone.io → API Keys
PINECONE_API_KEY=your_pinecone_api_key_here

# Groq API Key
# Get yours at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# E2B API Key (optional — enables sandboxed code execution for the Fixer agent)
# Get yours at: https://e2b.dev → Dashboard → API Keys
# If not set, the Fixer falls back to LLM reflection mode for all file types
E2B_API_KEY=your_e2b_api_key_here

# LangSmith (optional — enables tracing of all LLM calls and agent runs)
# Get your API key at: https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=true to activate; leave unset or set to false to disable
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=codesentinel
